{
  "permissions": {
    "defaultMode": "bypassPermissions",
    "allow": [
      "Bash(cat:*)",
      "Bash(find:*)",
      "Bash(gh:*)",
      "Bash(git:*)",
      "Bash(ls:*)",
      "Bash(man:*)",
      "Bash(nix:*)",
      "Bash(task:*)",
      "Bash(wc:*)",
      "Bash(which:*)",
      "Edit(*)",
      "Glob",
      "Grep",
      "SlashCommand",
      "Task",
      "TodoWrite",
      "WebFetch",
      "WebSearch",
      "Write(*)"
    ],
    "deny": [
      "Read(.env)",
      "Read(**/.env*)",
      "Read(**/*.cert)",
      "Read(**/*.crt)",
      "Read(**/*.key)",
      "Read(**/*.pem)",
      "Read(**/secret/**)",
      "Read(**/secrets/**)",
      "Read(**/credential/**)",
      "Read(**/credentials/**)",
      "Bash(rm -rf /)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf $HOME)",
      "Bash(sudo:*)",
      "Bash(diskutil:*)",
      "Bash(chmod:*)",
      "Bash(chown:*)",
      "Bash(dd:*)",
      "Bash(mkfs:*)",
      "Bash(mount:*)",
      "Bash(ln -s:*)"
    ]
  },
  "env": {
    "CLAUDE_CODE_ENABLE_TELEMETRY": "0",
    "BASH_DEFAULT_TIMEOUT_MS": "180000",
    "MAX_THINKING_TOKENS": "10000"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/validate-bash.sh"
          }
        ]
      }
    ]
  }
}
