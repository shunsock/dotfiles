{
  "env": {
    "CLAUDE_CODE_ENABLE_TELEMETRY": "0",
    "BASH_DEFAULT_TIMEOUT_MS": "180000",
    "MAX_THINKING_TOKENS": "10000",
    "CLAUDE_CODE_NO_FLICKER": "1"
  },
  "permissions": {
    "allow": [
      "Bash(cat:*)",
      "Bash(find:*)",
      "Bash(gh:*)",
      "Bash(git:*)",
      "Bash(ls:*)",
      "Bash(man:*)",
      "Bash(nix:*)",
      "Bash(task:*)",
      "Bash(wc:*)",
      "Bash(which:*)",
      "Edit(*)",
      "Glob",
      "Grep",
      "SlashCommand",
      "Task",
      "TodoWrite",
      "WebFetch",
      "WebSearch",
      "Write(*)"
    ],
    "deny": [
      "Read(.env)",
      "Read(**/.env*)",
      "Read(**/*.cert)",
      "Read(**/*.crt)",
      "Read(**/*.key)",
      "Read(**/*.pem)",
      "Read(**/secret/**)",
      "Read(**/secrets/**)",
      "Read(**/credential/**)",
      "Read(**/credentials/**)",
      "Bash(rm -rf /)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf $HOME)",
      "Bash(sudo:*)",
      "Bash(diskutil:*)",
      "Bash(chmod:*)",
      "Bash(chown:*)",
      "Bash(dd:*)",
      "Bash(mkfs:*)",
      "Bash(mount:*)",
      "Bash(ln -s:*)"
    ],
    "defaultMode": "bypassPermissions"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "dotnet run $HOME/.claude/hooks/validate_bash.cs"
          },
          {
            "type": "command",
            "command": "dotnet run $HOME/.claude/hooks/pr_submission_via_skill.cs"
          },
          {
            "type": "command",
            "command": "dotnet run $HOME/.claude/hooks/quality_assurance_via_skill.cs"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "dotnet run $HOME/.claude/hooks/require_tasks.cs"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "dotnet run $HOME/.claude/hooks/trigger_ci_fix.cs"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "dotnet run $HOME/.claude/hooks/write_structured_comment.cs"
          },
          {
            "type": "command",
            "command": "dotnet run $HOME/.claude/hooks/clean_comment_out.cs"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "dotnet run $HOME/.claude/hooks/block_stop_on_open_tasks.cs"
          }
        ]
      }
    ]
  },
  "extraKnownMarketplaces": {
    "anthropic-agent-skills": {
      "source": {
        "source": "github",
        "repo": "anthropics/skills"
      }
    }
  },
  "skipDangerousModePermissionPrompt": true,
  "enabledPlugins": {
    "document-skills@anthropic-agent-skills": true
  },
  "editorMode": "vim",
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh",
    "refreshInterval": 10
  }
}
